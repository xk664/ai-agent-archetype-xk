            <dependency>
                <groupId>cn.bugstack.wrench</groupId>
                <artifactId>xfg-wrench-starter-design-framework</artifactId>
                <version>3.0.0</version>
            </dependency>

            <!-- 工程模块 -->
            <dependency>
                <groupId>cn.bugstack.ai</groupId>
                <artifactId>ai-agent-scaffold-xk-api</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>cn.bugstack.ai</groupId>
                <artifactId>ai-agent-scaffold-xk-domain</artifactId>
